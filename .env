# Server Configuration
PORT=5050
NODE_ENV=development

# Database Settings
# Set MONGO_URI to connect to MongoDB Atlas or local MongoDB.
# Leave empty to trigger the Resilient In-Memory Mock Database Mode (fully functional without MongoDB!).
MONGO_URI=

# Security & Auth
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRE=7d

# Cloudinary Storage Configuration
# Leave empty to fallback to local folder upload (saved in backend/uploads/).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Settings (Nodemailer)
# Leave empty to trigger automated Ethereal Email generation or console logging.
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@inventoryapp.com

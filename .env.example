# Server Configuration
PORT=5050
NODE_ENV=development

# Database Settings
# Set MONGO_URI to connect to your MongoDB Atlas cluster. If left empty, the server will run in "Resilient Mock DB Mode" using in-memory arrays.
MONGO_URI=mongodb://localhost:27017/inventory_db

# Security & Auth
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_EXPIRE=7d

# Cloudinary Storage Configuration
# Set these keys to enable image uploading to Cloudinary. If left empty, the backend will fallback to "Local File Storage" in backend/uploads/.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Settings (Nodemailer)
# Set these to send real email notifications. If left empty, the backend will automatically generate a free Ethereal Mail account or log emails to the console.
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=585
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@inventoryapp.com
